{
  "name": "@featctrl/typescript",
  "version": "0.1.0",
  "description": "FeatCtrl TypeScript SDK — SSE client for Node.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc --project tsconfig.test.json",
    "test:unit": "node --import tsx/esm --test tests/unit/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
